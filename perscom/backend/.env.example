# ─────────────────────────────────────────────────────────────────
#  PERSCOM Advance — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── LICENSE (Required) ──────────────────────────────────────────
# Get your license key after subscribing at https://perscomadvance.com
PERSCOM_LICENSE_KEY=your_license_key_here

# Your deployment's public domain (used for license domain validation)
APP_DOMAIN=https://yourdomain.com

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ────────────────────────────────────────────────────
DB_PATH=./data/perscom.db

# ── Authentication ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_string_minimum_64_characters

# ── Discord Bot (Optional) ──────────────────────────────────────
# Configure your Discord bot in unit.config.json
# These can also be set here and referenced in unit.config.json
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10mb
