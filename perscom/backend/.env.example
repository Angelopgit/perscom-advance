# ─── PERSCOM Advance — Environment Configuration ─────────────────────────────
# Copy this file to .env and fill in your values before starting the server.
# DO NOT commit .env to source control.

# ── Required ─────────────────────────────────────────────────────────────────

# Your license key from perscomadvance.com
# Dev/local testing only: use PCMA-DEV-0000-0000-0000 (ignored in production)
PERSCOM_LICENSE_KEY=PCMA-XXXX-XXXX-XXXX-XXXX

# The exact URL users will access (no trailing slash)
APP_DOMAIN=http://localhost:3001

# 64-character hex secret for JWT signing
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING

# ── Optional ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# DISCORD_BOT_TOKEN=
